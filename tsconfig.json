{
	"compilerOptions": {
		"target": "ES2021",
		"useDefineForClassFields": true,
		"module": "ESNext",
		"lib": ["ES2021", "DOM", "DOM.Iterable"],
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"types": ["svelte"]
	},
	"include": ["src/**/*.ts", "src/**/*.svelte"]
}
