{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "Claude Code PR Dashboard",
	"version": "0.1.0",
	"identifier": "com.claude-code-pr-dashboard",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build"
	},
	"app": {
		"windows": [
			{
				"title": "Claude Code PR Dashboard",
				"width": 1400,
				"height": 900,
				"resizable": true,
				"fullscreen": false,
				"minWidth": 800,
				"minHeight": 600
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
	},
	"plugins": {
		"shell": {
			"open": true
		}
	}
}
